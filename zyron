            { id: 8, name: "🔥 30 Dias Seguidos", desc: "Acessou por 30 dias consecutivos", xp: 1000, icon: "🔥" }
        ];

        // Ranking
        const ranking = [
            { name: "João Silva", xp: 15420, level: "Diamante" },
            { name: "Maria Santos", xp: 12890, level: "Platina" },
            { name: "Pedro Oliveira", xp: 9870, level: "Ouro" },
            { name: "Você", xp: userXP, level: getLevelByXP(userXP) }
        ];

        // ==================== FUNÇÕES ====================
        function getLevelByXP(xp) {
            if (xp >= 10000) return "Diamante 💎";
            if (xp >= 5000) return "Platina 🥈";
            if (xp >= 2000) return "Ouro 🥇";
            if (xp >= 500) return "Prata 🥉";
            return "Bronze 🥉";
        }

        function addXP(amount) {
            userXP += amount;
            localStorage.setItem('zyron_xp', userXP);
            updateDashboard();
            checkBadges();
        }

        function checkBadges() {
            const newBadges = [];
            if (userCourses.length >= 1 && !userBadges.some(b => b.id === 1)) newBadges.push(allBadges[0]);
            if (userCourses.length >= 10 && !userBadges.some(b => b.id === 5)) newBadges.push(allBadges[4]);
            if (userXP >= 10000 && !userBadges.some(b => b.id === 7)) newBadges.push(allBadges[6]);
            
            newBadges.forEach(badge => {
                userBadges.push(badge);
                showAlert(`🏆 Nova Conquista: ${badge.name}! +${badge.xp} XP`, 'success');
                addXP(badge.xp);
            });
            localStorage.setItem('zyron_badges', JSON.stringify(userBadges));
        }

        function updateDashboard() {
            const totalCourses = allCourses.length;
            const totalStudents = allCourses.reduce((sum, c) => sum + (c.students || 0), 0);
            const totalRevenue = allCourses.reduce((sum, c) => sum + ((c.price || 0) * (c.students || 0)), 0);
            
            document.getElementById('statCourses').innerText = totalCourses;
            document.getElementById('statStudents').innerText = totalStudents.toLocaleString();
            document.getElementById('statRevenue').innerText = `R$ ${totalRevenue.toLocaleString()}`;
            document.getElementById('userLevel').innerText = getLevelByXP(userXP);
            document.getElementById('userXP').innerText = userXP.toLocaleString();
            document.getElementById('userBadges').innerText = `${userBadges.length}/${allBadges.length}`;
            
            renderBadges();
            renderRanking();
            renderCourses();
            renderAffiliates();
            renderForum();
            renderAnnouncements();
            renderFunnel();
            updateCharts();
        }

        function renderBadges() {
            const container = document.getElementById('badgesList');
            container.innerHTML = allBadges.map(badge => `
                <div class="card" style="width: 150px; text-align: center; padding: 1rem;">
                    <div style="font-size: 2rem;">${badge.icon}</div>
                    <div style="font-weight: bold; color: var(--text-light);">${badge.name}</div>
                    <div style="font-size: 0.7rem; color: var(--text-gray);">${badge.desc}</div>
                    ${userBadges.some(b => b.id === badge.id) ? '<span class="badge badge-success" style="margin-top: 0.5rem;">✅ Desbloqueado</span>' : '<span class="badge" style="background: var(--primary); margin-top: 0.5rem;">🔒 Bloqueado</span>'}
                </div>
            `).join('');
        }

        function renderRanking() {
            const sorted = [...ranking].sort((a,b) => b.xp - a.xp);
            const container = document.getElementById('rankingList');
            container.innerHTML = sorted.map((user, i) => `
                <div class="ranking-item">
                    <div class="ranking-position">${i+1}</div>
                    <div style="flex:1;"><strong style="color: var(--text-light);">${user.name}</strong><br><span style="font-size: 0.7rem;">${user.level}</span></div>
                    <div style="color: var(--accent); font-weight: bold;">${user.xp} XP</div>
                </div>
            `).join('');
        }

        function renderCourses() {
            const container = document.getElementById('coursesGrid');
            if (!container) return;
            container.innerHTML = allCourses.map(course => `
                <div class="course-card" onclick="openPaymentModal(${course.id})">
                    <div class="course-image"><div class="emoji">${course.emoji || '📚'}</div></div>
                    <div class="course-info">
                        <h3>${course.name}</h3>
                        <p>${course.description.substring(0, 80)}...</p>
                        <div class="course-price">R$ ${course.price}</div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.7rem;">
                            <span>⭐ ${course.rating || 4.8}</span>
                            <span>👥 ${course.students || 0} alunos</span>
                        </div>
                        <button class="btn-primary btn" style="width: 100%; margin-top: 0.5rem;">Comprar</button>
                    </div>
                </div>
            `).join('');
        }

        function renderAffiliates() {
            const container = document.getElementById('topAffiliatesList');
            if (!container) return;
            const topAffiliates = [
                { name: "Carlos Lima", sales: 47, commission: 1410 },
                { name: "Ana Paula", sales: 32, commission: 960 },
                { name: "Roberto Silva", sales: 28, commission: 840 }
            ];
            container.innerHTML = topAffiliates.map((aff, i) => `
                <div class="ranking-item">
                    <div class="ranking-position">${i+1}</div>
                    <div style="flex:1;"><strong>${aff.name}</strong><br><span style="font-size:0.7rem;">${aff.sales} vendas</span></div>
                    <div style="color: var(--success);">R$ ${aff.commission}</div>
                </div>
            `).join('');
        }

        function renderForum() {
            const container = document.getElementById('forumTopics');
            if (!container) return;
            if (forumTopics.length === 0) {
                container.innerHTML = '<p style="color: var(--text-gray);">Nenhum tópico ainda. Seja o primeiro!</p>';
                return;
            }
            container.innerHTML = forumTopics.slice(-5).reverse().map(topic => `
                <div style="padding: 0.8rem; border-bottom: 1px solid rgba(59,130,246,0.1);">
                    <strong style="color: var(--accent);">${topic.title}</strong>
                    <p style="color: var(--text-gray); font-size: 0.8rem;">${topic.content.substring(0, 100)}...</p>
                    <span style="font-size: 0.7rem; color: var(--text-gray);">por ${topic.author} • ${new Date(topic.date).toLocaleDateString()}</span>
                </div>
            `).join('');
        }

        function renderAnnouncements() {
            const container = document.getElementById('announcements');
            if (!container) return;
            container.innerHTML = `
                <div style="padding: 1rem; background: rgba(59,130,246,0.1); border-radius: 8px; margin-bottom: 0.5rem;">
                    <strong>🎉 Novos cursos disponíveis!</strong>
                    <p style="font-size: 0.8rem;">Confira os novos cursos de Marketing Digital.</p>
                </div>
                <div style="padding: 1rem; background: rgba(59,130,246,0.1); border-radius: 8px;">
                    <strong>🏆 Programa de Afiliados</strong>
                    <p style="font-size: 0.8rem;">Ganhe até 50% de comissão indicando cursos!</p>
                </div>
            `;
        }

        function renderFunnel() {
            const container = document.getElementById('funnelChart');
            if (!container) return;
            container.innerHTML = `
                <div style="margin: 1rem 0;"><span>👁️ Visualizações: 10.234</span><div class="progress-bar"><div class="progress-fill" style="width: 100%"></div></div></div>
                <div style="margin: 1rem 0;"><span>🛒 Clicaram: 3.456 (33.8%)</span><div class="progress-bar"><div class="progress-fill" style="width: 33.8%"></div></div></div>
                <div style="margin: 1rem 0;"><span>➕ Add Carrinho: 1.234 (12.1%)</span><div class="progress-bar"><div class="progress-fill" style="width: 12.1%"></div></div></div>
                <div style="margin: 1rem 0;"><span>✅ Compraram: 876 (8.6%)</span><div class="progress-bar"><div class="progress-fill" style="width: 8.6%"></div></div></div>
            `;
        }

        function updateCharts() {
            const ctx = document.getElementById('revenueChart')?.getContext('2d');
            if (ctx) {
                new Chart(ctx, {
                    type: 'line',
                    data: { labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun'], datasets: [{ label: 'Receita', data: [12500, 15800, 18900, 22400, 26700, 31200], borderColor: '#3b82f6', tension: 0.4, fill: true, backgroundColor: 'rgba(59,130,246,0.1)' }] },
                    options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#94a3b8' } } }, scales: { y: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' } }, x: { ticks: { color: '#94a3b8' }, grid: { color: '#1e293b' } } } }
                });
            }
        }

        function createNewCourse() {
            const title = document.getElementById('newCourseTitle').value;
            const desc = document.getElementById('newCourseDesc').value;
            const category = document.getElementById('newCourseCategory').value;
            const level = document.getElementById('newCourseLevel').value;
            const price = parseFloat(document.getElementById('newCoursePrice').value);
            const duration = document.getElementById('newCourseDuration').value;
            const emoji = document.getElementById('newCourseEmoji').value;
            
            if (!title || !desc || !price) { showAlert('❌ Preencha todos os campos!', 'error'); return; }
            
            const newCourse = { id: Date.now(), name: title, description: desc, category, level, price, duration, emoji, students: 0, isUserCreated: true };
            userCourses.push(newCourse);
            localStorage.setItem('zyron_courses', JSON.stringify(userCourses));
            allCourses = [...defaultCourses, ...userCourses.map((c, i) => ({ ...c, id: 1000 + i }))];
            
            addXP(500);
            showAlert(`✅ Curso "${title}" criado com sucesso! +500 XP`, 'success');
            document.getElementById('newCourseTitle').value = '';
            document.getElementById('newCourseDesc').value = '';
            document.getElementById('newCoursePrice').value = '';
            updateDashboard();
            renderCourses();
        }

        function createTopic() {
            const title = document.getElementById('topicTitle')?.value;
            const content = document.getElementById('topicContent')?.value;
            if (!title || !content) { showAlert('❌ Preencha todos os campos!', 'error'); return; }
            forumTopics.push({ title, content, author: "Você", date: new Date().toISOString() });
            localStorage.setItem('zyron_topics', JSON.stringify(forumTopics));
            showAlert('✅ Tópico publicado na comunidade!', 'success');
            closeModal('newTopic');
            renderForum();
        }

        function copyAffiliateLink() { navigator.clipboard.writeText('https://zyron.com/ref/SEU_ID'); showAlert('✅ Link copiado!', 'success'); }

        function openPaymentModal(courseId) {
            selectedCourse = allCourses.find(c => c.id === courseId);
            if (!selectedCourse) return;
            const modal = document.getElementById('paymentModal');
            const content = document.getElementById('paymentContent');
            document.getElementById('paymentTitle').innerHTML = `${selectedCourse.name} - R$ ${selectedCourse.price}`;
            content.innerHTML = `
                <div class="form-group"><label>Método de Pagamento</label><select id="payMethod"><option>💳 Cartão de Crédito</option><option>📱 PIX</option><option>📄 Boleto</option></select></div>
                <div id="cardFields"><div class="form-group"><label>Número do Cartão</label><input type="text" placeholder="4242 4242 4242 4242"></div><div class="form-group"><label>Nome</label><input type="text"></div><div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;"><div><label>Validade</label><input placeholder="MM/AA"></div><div><label>CVV</label><input placeholder="123"></div></div></div>
                <button class="btn-pay" onclick="processPayment()">✅ Pagar R$ ${selectedCourse.price}</button>
                <div class="info-box" style="margin-top:1rem; padding:0.8rem; background:rgba(59,130,246,0.1); border-radius:8px;"><p>🔐 Ambiente de Teste - Use 4242 4242 4242 4242</p></div>
            `;
            modal.classList.add('active');
        }

        function processPayment() {
            showAlert(`✅ Pagamento aprovado! Curso ${selectedCourse.name} adicionado à sua conta. +300 XP`, 'success');
            addXP(300);
            closeModal('payment');
        }

        function showAlert(message, type = 'success') {
            const colors = { success: '#10b981', error: '#ef4444', info: '#3b82f6' };
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert';
            alertDiv.style.background = colors[type];
            alertDiv.textContent = message;
            document.body.appendChild(alertDiv);
            setTimeout(() => { alertDiv.style.animation = 'slideOut 0.3s ease'; setTimeout(() => alertDiv.remove(), 300); }, 3000);
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.getElementById(`tab-${tabId}`).classList.add('active');
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
            event.target.classList.add('active');
            if (tabId === 'gamificacao') renderBadges();
            if (tabId === 'afiliados') renderAffiliates();
            if (tabId === 'cursos') renderCourses();
        }

        function openModal(type) { document.getElementById(`${type}Modal`).classList.add('active'); document.body.style.overflow = 'hidden'; }
        function closeModal(type) { document.getElementById(`${type}Modal`).classList.remove('active'); document.body.style.overflow = ''; }
        function handleLogin() { showAlert('✨ Login realizado!'); closeModal('login'); }
        function handleRegister() { showAlert('🎉 Cadastro realizado!'); closeModal('register'); }

        window.onclick = function(event) { if (event.target.classList.contains('modal')) { event.target.classList.remove('active'); document.body.style.overflow = ''; } };

        // Inicialização
        updateDashboard();
        renderCourses();
    </script>
</body>
</html>site Zyron completo 