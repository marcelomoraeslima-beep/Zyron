                </div>
            </div>

            <!-- Cursos -->
            <div id="tab-cursos" class="tab-content">
                <div class="courses-grid" id="coursesGrid"></div>
            </div>

            <!-- Afiliados -->
            <div id="tab-afiliados" class="tab-content">
