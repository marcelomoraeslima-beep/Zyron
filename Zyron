<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Zyron - Plataforma de Cursos</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --preto: #000000;
            --preto-claro: #0a0a0a;
            --preto-medio: #111111;
            --azul: #0066ff;
            --azul-claro: #3399ff;
            --azul-escuro: #0044cc;
            --azul-gradiente: linear-gradient(135deg, #0066ff, #0044cc);
            --branco: #ffffff;
            --cinza: #888888;
            --cinza-claro: #aaaaaa;
            --bitcoin: #f7931a;
            --bitcoin-escuro: #e67e22;
            --sucesso: #00ff88;
            --erro: #ff3333;
        }

        body {
            background: var(--preto);
            min-height: 100vh;
        }

        /* ==================== HEADER ==================== */
        header {
            background: var(--preto);
            padding: 1rem 0;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            border-bottom: 2px solid var(--azul);
            transition: all 0.5s ease-in-out;
            box-shadow: 0 0 20px rgba(0, 102, 255, 0.2);
        }

        .header-escondido {
            transform: translateY(-120%);
            opacity: 0;
            visibility: hidden;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--azul);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .bitcoin-logo {
            font-size: 1.8rem;
            animation: bitcoinPulse 2s infinite;
            color: var(--bitcoin);
        }

        @keyframes bitcoinPulse {
            0%, 100% { transform: scale(1); text-shadow: 0 0 0px var(--bitcoin); }
            50% { transform: scale(1.1); text-shadow: 0 0 10px var(--bitcoin); }
        }

        .nav-menu {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .nav-menu a {
            color: var(--branco);
            text-decoration: none;
            padding: 0.5rem 1rem;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 500;
        }

        .nav-menu a:hover {
            color: var(--azul);
        }

        .btn {
            padding: 0.8rem 1.5rem;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-azul {
            background: var(--azul-gradiente);
            color: white;
        }

        .btn-azul:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(0, 102, 255, 0.5);
        }

        .btn-transparente {
            background: transparent;
            border: 2px solid var(--azul);
            color: var(--azul);
        }

        .btn-transparente:hover {
            background: var(--azul);
            color: white;
            transform: translateY(-2px);
        }

        .btn-bitcoin {
            background: var(--bitcoin);
            color: black;
            font-weight: bold;
        }

        .btn-bitcoin:hover {
            background: var(--bitcoin-escuro);
            transform: translateY(-2px);
            box-shadow: 0 0 15px rgba(247, 147, 26, 0.5);
        }

        .main-content {
            padding-top: 90px;
            padding-bottom: 50px;
        }

        /* ==================== HERO SECTION ==================== */
        .hero {
            text-align: center;
            padding: 80px 20px;
            background: linear-gradient(135deg, var(--preto), var(--azul-escuro));
            border-radius: 20px;
            margin-bottom: 50px;
            border: 1px solid var(--azul);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '₿ ₿ ₿ ₿ ₿';
            position: absolute;
            font-size: 8rem;
            opacity: 0.05;
            bottom: -30px;
            right: -30px;
            animation: floatBitcoin 4s ease-in-out infinite;
            color: var(--bitcoin);
        }

        @keyframes floatBitcoin {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        .hero h1 {
            color: var(--branco);
            font-size: 2.8rem;
            margin-bottom: 1rem;
            position: relative;
            z-index: 1;
        }

        .hero h1 span {
            color: var(--bitcoin);
            text-shadow: 0 0 10px var(--bitcoin);
        }

        .hero p {
            color: var(--cinza-claro);
            margin-bottom: 2rem;
            font-size: 1.2rem;
            position: relative;
            z-index: 1;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
        }

        /* ==================== STATS CARDS ==================== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 1.5rem;
            margin-bottom: 50px;
        }

        .stat-card {
            background: var(--preto-medio);
            border-radius: 16px;
            padding: 1.8rem;
            text-align: center;
            border: 1px solid var(--azul);
            transition: all 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--bitcoin);
            box-shadow: 0 0 20px rgba(0, 102, 255, 0.2);
        }

        .stat-icon {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: bold;
            color: var(--azul);
            margin-bottom: 0.5rem;
        }

        .stat-bitcoin-value {
            font-size: 2rem;
            font-weight: bold;
            color: var(--bitcoin);
        }

        .stat-label {
            color: var(--cinza);
            font-size: 0.9rem;
        }

        /* ==================== CURSOS GRID ==================== */
        .section-title {
            text-align: center;
            margin-bottom: 2rem;
        }

        .section-title h2 {
            color: var(--branco);
            font-size: 2rem;
        }

        .section-title h2 span {
            color: var(--bitcoin);
        }

        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.8rem;
            margin-top: 1rem;
        }

        .course-card {
            background: var(--preto-medio);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--azul);
            transition: all 0.3s;
            cursor: pointer;
        }

        .course-card:hover {
            transform: translateY(-8px);
            border-color: var(--bitcoin);
            box-shadow: 0 0 25px rgba(0, 102, 255, 0.3);
        }

        .course-image {
            background: linear-gradient(135deg, var(--azul), var(--azul-escuro));
            padding: 1.8rem;
            text-align: center;
        }

        .course-image .emoji {
            font-size: 3.5rem;
        }

        .course-info {
            padding: 1.2rem;
        }

        .course-info h3 {
            color: var(--branco);
            margin-bottom: 0.5rem;
            font-size: 1.2rem;
        }

        .course-info p {
            color: var(--cinza);
            font-size: 0.85rem;
            line-height: 1.4;
        }

        .course-price {
            font-size: 1.4rem;
            font-weight: bold;
            color: var(--azul);
            margin: 0.8rem 0 0.3rem;
        }

        .bitcoin-price {
            font-size: 0.8rem;
            color: var(--bitcoin);
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin-bottom: 0.5rem;
        }

        .course-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.7rem;
            color: var(--cinza);
            margin-bottom: 0.8rem;
        }

        .btn-buy {
            width: 100%;
            padding: 0.8rem;
            background: var(--azul-gradiente);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-buy:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 10px var(--azul);
        }

        /* ==================== DEPOIMENTOS ==================== */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .testimonial-card {
            background: var(--preto-medio);
            border-radius: 16px;
            padding: 1.5rem;
            border: 1px solid var(--azul);
        }

        .testimonial-text {
            color: var(--cinza-claro);
            font-style: italic;
            margin-bottom: 1rem;
            line-height: 1.5;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .testimonial-avatar {
            width: 45px;
            height: 45px;
            background: var(--azul-gradiente);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        .testimonial-name {
            color: var(--branco);
            font-weight: bold;
        }

        .testimonial-rating {
            color: var(--bitcoin);
            font-size: 0.8rem;
        }

        /* ==================== NEWSLETTER ==================== */
        .newsletter {
            background: linear-gradient(135deg, var(--preto), var(--azul-escuro));
            border-radius: 20px;
            padding: 3rem;
            text-align: center;
            margin-top: 3rem;
            border: 1px solid var(--azul);
        }

        .newsletter h3 {
            color: var(--branco);
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .newsletter p {
            color: var(--cinza);
            margin-bottom: 1.5rem;
        }

        .newsletter-form {
            display: flex;
            gap: 1rem;
            max-width: 500px;
            margin: 0 auto;
            flex-wrap: wrap;
        }

        .newsletter-form input {
            flex: 1;
            padding: 0.8rem;
            background: var(--preto);
            border: 1px solid var(--azul);
            border-radius: 8px;
            color: white;
        }

        .newsletter-form button {
            padding: 0.8rem 2rem;
            background: var(--azul-gradiente);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        /* ==================== FOOTER ==================== */
        footer {
            background: var(--preto);
            padding: 3rem 0 2rem;
            margin-top: 3rem;
            border-top: 1px solid var(--azul);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .footer-col h4 {
            color: var(--azul);
            margin-bottom: 1rem;
        }

        .footer-col ul {
            list-style: none;
        }

        .footer-col ul li {
            margin-bottom: 0.5rem;
        }

        .footer-col ul li a {
            color: var(--cinza);
            text-decoration: none;
            transition: color 0.3s;
        }

        .footer-col ul li a:hover {
            color: var(--azul);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 2rem;
            border-top: 1px solid rgba(0, 102, 255, 0.2);
            color: var(--cinza);
        }

        /* ==================== MODAL ==================== */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            z-index: 2000;
            justify-content: center;
            align-items: center;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--preto-medio);
            border-radius: 20px;
            max-width: 450px;
            width: 90%;
            padding: 2rem;
            border: 1px solid var(--azul);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .modal-header h2 {
            color: var(--branco);
        }

        .close-modal {
            font-size: 1.8rem;
            cursor: pointer;
            color: var(--cinza);
        }

        .close-modal:hover {
            color: var(--azul);
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--branco);
        }

        .form-group input {
            width: 100%;
            padding: 0.8rem;
            background: var(--preto);
            border: 1px solid var(--azul);
            border-radius: 8px;
            color: white;
        }

        .btn-pay {
            width: 100%;
            padding: 1rem;
            background: var(--azul-gradiente);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 1rem;
        }

        .btn-pay:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 15px var(--azul);
        }

        /* ==================== ALERT ==================== */
        .alert {
            position: fixed;
            top: 100px;
            right: 20px;
            padding: 15px 25px;
            border-radius: 8px;
            color: white;
            z-index: 3000;
            animation: slideIn 0.3s ease;
            font-weight: bold;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @keyframes slideOut {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }

        /* ==================== RESPONSIVO ==================== */
        @media (max-width: 768px) {
            .hero h1 { font-size: 1.8rem; }
            .hero { padding: 50px 20px; }
            .courses-grid { grid-template-columns: 1fr; }
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .newsletter-form { flex-direction: column; }
            .header-content { flex-direction: column; text-align: center; }
            .nav-menu { justify-content: center; }
        }
    </style>
</head>
<body>

    <!-- HEADER - VAI SUMIR QUANDO LOGAR -->
    <header id="mainHeader">
        <div class="container">
            <div class="header-content">
                <div class="logo">
